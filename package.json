{
  "name": "skywatch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Live flight tracker — Deck.gl + Mapbox + OpenSky. Phase 1.",
  "scripts": {
    "dev": "concurrently -n proxy,vite -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/proxy.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.3",
    "@deck.gl/layers": "^9.3.3",
    "@deck.gl/mapbox": "^9.3.3",
    "d3-geo": "^3.1.1",
    "d3-timer": "^3.0.1",
    "express": "^4.19.0",
    "mapbox-gl": "^3.5.0",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/d3-timer": "^3.0.2",
    "@types/express": "^4.17.21",
    "@types/mapbox-gl": "^3.1.0",
    "@types/three": "^0.165.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
